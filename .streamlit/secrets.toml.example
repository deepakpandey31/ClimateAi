# ── Streamlit Secrets Template ────────────────────────────────────────────────
# IMPORTANT: This file is a TEMPLATE only.
# DO NOT commit real credentials here.
# 
# In Streamlit Community Cloud:
#   Go to your app → ⋮ menu → Settings → Secrets
#   Paste the content below with your real values filled in.
# ──────────────────────────────────────────────────────────────────────────────

GEE_PROJECT_ID = "smartqueue-b1647"

# Paste your full GEE Service Account JSON as a single-line string.
# Get it from: Google Cloud Console → IAM → Service Accounts → Create Key → JSON
# Then minify it to one line at: https://jsonformatter.org/json-minify
GEE_SERVICE_ACCOUNT_JSON = '{"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\\n...\\n-----END RSA PRIVATE KEY-----\\n","client_email":"YOUR_SA@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'
